{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-git-review",
  "name": {
    "en": "Git Review",
    "ko": "\uae43 \ub9ac\ubdf0"
  },
  "version": "0.0.1",
  "description": {
    "en": "Review a branch or worktree's changes: a diff surface, comments as a deterministic record contract, injecting comments into the target's terminal, and approve then local-merge. Git runs directly.",
    "ko": "\ube0c\ub79c\uce58\u00b7\uc6cc\ud06c\ud2b8\ub9ac \ubcc0\uacbd\uc744 \ub9ac\ubdf0 \u2014 diff \ud45c\uba74, \uacb0\uc815\uc801 \ub808\ucf54\ub4dc \uacc4\uc57d\uc73c\ub85c\uc11c\uc758 \ucf54\uba58\ud2b8, \ucf54\uba58\ud2b8\ub97c \ub300\uc0c1 \ud130\ubbf8\ub110\uc5d0 \uc8fc\uc785, \uc2b9\uc778 \ud6c4 \ub85c\uceec \uba38\uc9c0. git \uc740 \uc9c1\uc811 \uc2e4\ud589."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "commands",
    "commands:destructive",
    "data",
    "terminal",
    "terminal:write"
  ],
  "contributes": {
    "commands": [
      {
        "name": "diff.files",
        "title": {
          "en": "List changed files",
          "ko": "\ubcc0\uacbd \ud30c\uc77c \ubaa9\ub85d"
        }
      },
      {
        "name": "diff.read",
        "title": {
          "en": "Read the diff hunks",
          "ko": "diff \ubcf8\ubb38 \uc870\ud68c"
        }
      },
      {
        "name": "comment.add",
        "title": {
          "en": "Add a review comment",
          "ko": "\ub9ac\ubdf0 \ucf54\uba58\ud2b8 \ucd94\uac00"
        }
      },
      {
        "name": "comment.list",
        "title": {
          "en": "List review comments",
          "ko": "\ub9ac\ubdf0 \ucf54\uba58\ud2b8 \ubaa9\ub85d"
        }
      },
      {
        "name": "comment.resolve",
        "title": {
          "en": "Resolve a comment",
          "ko": "\ucf54\uba58\ud2b8 \ud574\uc18c"
        }
      },
      {
        "name": "comment.reopen",
        "title": {
          "en": "Reopen a comment",
          "ko": "\ucf54\uba58\ud2b8 \uc7ac\uac1c"
        }
      },
      {
        "name": "comment.remove",
        "title": {
          "en": "Remove a comment",
          "ko": "\ucf54\uba58\ud2b8 \uc0ad\uc81c"
        },
        "danger": "destructive"
      },
      {
        "name": "comment.send",
        "title": {
          "en": "Send comments to the target terminal",
          "ko": "\ucf54\uba58\ud2b8\ub97c \ub300\uc0c1 \ud130\ubbf8\ub110\ub85c \uc804\uc1a1"
        }
      },
      {
        "name": "approve",
        "title": {
          "en": "Approve the target's changes",
          "ko": "\ub300\uc0c1 \ubcc0\uacbd \uc2b9\uc778"
        }
      },
      {
        "name": "approve.revoke",
        "title": {
          "ko": "\uc2b9\uc778\uc744 \ucca0\ud68c\ud569\ub2c8\ub2e4",
          "en": "Withdraws an approval"
        }
      },
      {
        "name": "merge",
        "title": {
          "en": "Merge the approved target",
          "ko": "\uc2b9\uc778\ub41c \ub300\uc0c1 \uba38\uc9c0"
        },
        "danger": "destructive"
      }
    ],
    "views": [
      {
        "id": "view",
        "title": {
          "en": "Review",
          "ko": "\ub9ac\ubdf0"
        },
        "icon": "\u25d1",
        "placements": [
          "sidebar-right",
          "content"
        ],
        "defaultPlacement": "content",
        "status": [
          "loading",
          "clean",
          "changed",
          "approved",
          "error"
        ],
        "sidebar": {
          "left": [
            {
              "ref": "self.files",
              "instance": "per-view"
            }
          ],
          "right": [
            {
              "ref": "self.comments",
              "instance": "per-view"
            }
          ]
        }
      },
      {
        "id": "files",
        "title": {
          "en": "Changed Files",
          "ko": "변경 파일"
        },
        "icon": "≣",
        "placements": [
          "rail"
        ]
      },
      {
        "id": "comments",
        "title": {
          "en": "Review Comments",
          "ko": "리뷰 코멘트"
        },
        "icon": "💬",
        "placements": [
          "rail"
        ]
      }
    ],
    "nodes": [
      {
        "id": "refresh",
        "description": {
          "en": "Refresh button (reload files + comments)",
          "ko": "\uc0c8\ub85c\uace0\uce68 \ubc84\ud2bc(\ud30c\uc77c\u00b7\ucf54\uba58\ud2b8 \uc7ac\ub85c\ub4dc)"
        }
      },
      {
        "id": "file",
        "description": {
          "en": "Changed file row (click = show its diff). data-node=\"file/<key>\"",
          "ko": "\ubcc0\uacbd \ud30c\uc77c \ud589(\ud074\ub9ad=diff \ud45c\uc2dc). data-node=\"file/<\ud0a4>\""
        }
      },
      {
        "id": "comment",
        "description": {
          "en": "Comment row. data-node=\"comment/<id>\"",
          "ko": "\ucf54\uba58\ud2b8 \ud589. data-node=\"comment/<id>\""
        }
      },
      {
        "id": "resolve",
        "description": {
          "en": "Per-comment resolve toggle. data-node=\"resolve/<id>\"",
          "ko": "\ucf54\uba58\ud2b8\ubcc4 \ud574\uc18c \ud1a0\uae00. data-node=\"resolve/<id>\""
        }
      },
      {
        "id": "approve",
        "description": {
          "en": "Approve button for the target",
          "ko": "\ub300\uc0c1 \uc2b9\uc778 \ubc84\ud2bc"
        }
      }
    ]
  },
  "consumes": [
    {
      "id": "soksak-spec-plugin-git",
      "range": "0.0.1"
    }
  ]
}
